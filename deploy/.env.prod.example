# 本地手动部署用（docker compose -f docker-compose.prod.yml ...）。
# Terraform 自动部署时这些值由 cloud-init 写入服务器，无需本文件。

# SiliconFlow API key（query 编码用，1024 维 BGE-M3）
EMBED_API_KEY=sk-xxxxxxxxxxxxxxxx
EMBED_API_BASE=https://api.siliconflow.cn/v1
EMBED_API_MODEL=BAAI/bge-m3

# Caddy 站点地址：填域名(自动HTTPS) 或 :80(无域名按IP访问)
SITE_ADDRESS=:80
