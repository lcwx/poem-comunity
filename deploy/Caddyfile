# Caddy 反代配置。SITE_ADDRESS 由 compose 注入：
#   - 填域名（如 poems.example.com）→ Caddy 自动申请 Let's Encrypt 证书，HTTPS
#   - 填 :80 → 仅 HTTP，用服务器 IP 直接访问（无域名时）
{$SITE_ADDRESS} {
	encode gzip

	# /api/* 直接代理到后端，省去前端中转
	handle /api/* {
		uri strip_prefix /api
		reverse_proxy backend:8000
	}

	# 其余全部交给 Next.js 前端
	handle {
		reverse_proxy frontend:3000
	}
}
